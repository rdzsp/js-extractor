{
  "manifest_version": 2,
  "name": "JS Extractor",
  "version": "1.0.0",
  "description": "Extract regex matches from JavaScript sources on any page",
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "JS Extractor"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "js-extractor@rdzsp.id",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "data_types": [],
        "tracking": false
      }
    }
  }
}